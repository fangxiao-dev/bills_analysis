# Docker environment configuration example
# Copy to .env.docker and fill in real keys before running: docker compose up

# Azure Document Intelligence API
AZURE_DI_ENDPOINT="https://your-resource.cognitiveservices.azure.com/"
AZURE_DI_KEY="your-api-key-here"

# Azure OpenAI API
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
AZURE_OPENAI_KEY="your-api-key-here"

# Optional: Business configuration
# OFFICE_EXPECTED_RECEIVER="Your Company Name"
# BACKEND_FILE_TIMEOUT_SEC=180
